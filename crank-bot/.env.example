# RPC endpoint — use a dedicated provider (Helius, QuickNode, etc.)
RPC_ENDPOINT=https://devnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

# Path to the bot's keypair JSON file (must be funded to pay transaction fees)
KEYPAIR_PATH=/home/user/.config/solana/crank-bot.json

# How often the epoch crank loop runs (milliseconds). Default: 5 minutes.
EPOCH_CRANK_INTERVAL_MS=300000

# How often the reward accumulator crank runs (milliseconds). Default: 10 minutes.
REWARD_CRANK_INTERVAL_MS=600000

# How often the liquidation monitor polls for unhealthy positions (milliseconds). Default: 30 seconds.
LIQUIDATION_POLL_INTERVAL_MS=30000

# How often the governance monitor polls for executable proposals (milliseconds). Default: 5 minutes.
GOVERNANCE_POLL_INTERVAL_MS=300000

# How often the unstake claimer scans for matured WithdrawalTickets (milliseconds). Default: 10 minutes.
UNSTAKE_CLAIMER_INTERVAL_MS=600000

# Health factor threshold below which to trigger liquidation (scaled by 1e18, so 1.0 = 1000000000000000000).
# Set slightly below 1.0 to avoid racing against on-chain checks. Default: 0.99
LIQUIDATION_HF_THRESHOLD=990000000000000000

# Maximum slippage in basis points for Jupiter swaps during liquidation. Default: 100 (1%)
LIQUIDATION_SLIPPAGE_BPS=100
